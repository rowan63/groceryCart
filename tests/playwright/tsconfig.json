{
  "compilerOptions": {
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "jsx": "preserve",
    "baseUrl": ".",
"paths": {
  "@repo/db/*": ["../../packages/db/src/*"],
  "@repo/env/*": ["../../packages/env/src/*"],
  "@repo/utils/*": ["../../packages/utils/src/*"]
}
  },
  "include": ["**/*.ts", "**/*.tsx"]
}